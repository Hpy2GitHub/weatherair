{
  "name": "weather-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:npm": "vite build --mode npm",
    "build:apache": "tsc && vite build --mode apache",
    "build:github": "vite build --mode github",
    "build:check": "tsc && vite build",
    "check": "tsc --noEmit && eslint . --ignore-pattern vite.config.ts",
    "check-components": "python util/check_components.py",
    "type-check": "tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint ."
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "suncalc": "1.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "10.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "globals": "17.5.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "^5.4.2",
    "vite-plugin-pwa": "1.2.0"
  }
}
